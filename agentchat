#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_DIR="$ROOT_DIR/cli"
ORIGINAL_CWD="$PWD"

BUN_BIN="${BUN_BIN:-$HOME/.bun/bin/bun}"

if command -v bun >/dev/null 2>&1; then
  export AGENTCHAT_SESSION_CWD="${AGENTCHAT_SESSION_CWD:-$ORIGINAL_CWD}"
  cd "$CLI_DIR"
  exec bun src/index.ts "$@"
fi

if [ -x "$BUN_BIN" ]; then
  export AGENTCHAT_SESSION_CWD="${AGENTCHAT_SESSION_CWD:-$ORIGINAL_CWD}"
  cd "$CLI_DIR"
  exec "$BUN_BIN" src/index.ts "$@"
fi

export AGENTCHAT_SESSION_CWD="${AGENTCHAT_SESSION_CWD:-$ORIGINAL_CWD}"
cd "$CLI_DIR"
exec "$ROOT_DIR/node_modules/.bin/tsx" src/index.ts "$@"
